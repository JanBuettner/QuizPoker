{
  "name": "quizpoker",
  "version": "1.0.0",
  "description": "QuizPoker - Poker meets estimation quiz",
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build --config client/vite.config.ts",
    "start": "node --loader tsx server/index.ts",
    "render:build": "npm install --include=dev && npm run build"
  },
  "dependencies": {
    "@discord/embedded-app-sdk": "^2.4.1",
    "express": "^5.1.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.2"
  }
}
